---
// Hero.astro
interface Props {
  slides: any[];
}
const { slides } = Astro.props;
---
<section class="relative w-full h-[calc(100dvh-64px)] md:h-[calc(100dvh-80px)] overflow-hidden bg-brand-light flex items-center">
  <!-- Background Slider -->
  <div class="absolute inset-0 z-0">
    {slides.map((slide, idx) => (
      <div 
        class={`hero-slide absolute inset-0 transition-opacity duration-1000 ease-in-out ${idx === 0 ? 'opacity-100 z-10' : 'opacity-0 z-0'}`}
        data-index={idx}
      >
        <img 
          src={slide.entry.backgroundImage} 
          alt={slide.entry.title} 
          class="w-full h-full object-cover"
        />
        <div class="absolute inset-0 bg-neutral-dark/40 backdrop-blur-[1px]"></div>
      </div>
    ))}
  </div>

  <!-- Content Overlays -->
  <div class="relative z-20 max-w-[1400px] w-full mx-auto px-6">
    <!-- Asymmetric layout with variance:8. Floating card aligned straight -->
    <div class="w-full max-w-xl bg-white/95 backdrop-blur-md p-8 md:p-10 rounded-2xl shadow-xl border border-brand-accent/50 translate-x-1 md:translate-x-12 transition-spring">
      {slides.map((slide, idx) => (
        <div 
          class={`hero-content-block transition-all duration-500 ${idx === 0 ? 'block opacity-100' : 'hidden opacity-0'}`}
          data-index={idx}
        >
          <span class="text-[10px] tracking-[0.2em] text-brand font-bold uppercase mb-2 block">Destacado</span>
          <h1 class="text-2xl md:text-4xl font-extrabold text-neutral-dark tracking-tight leading-tight mb-4">
            {slide.entry.title}
          </h1>
          <p class="text-neutral-muted text-xs md:text-sm leading-relaxed mb-6 max-w-[45ch]">
            {slide.entry.description}
          </p>
          <div>
            <a 
              href={slide.entry.ctaLink} 
              target="_blank" 
              rel="noopener noreferrer" 
              class="inline-block bg-brand text-white px-6 py-3 rounded-lg hover:bg-brand-hover transition-spring hover-lift-rotate text-xs uppercase tracking-wider font-semibold"
            >
              {slide.entry.ctaLabel}
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- Slide indicators -->
  <div class="absolute bottom-8 right-8 z-30 flex gap-3">
    {slides.map((_, idx) => (
      <button 
        class={`hero-dot w-3 h-3 rounded-full border border-white transition-all ${idx === 0 ? 'bg-white scale-125' : 'bg-transparent'}`}
        data-index={idx}
        aria-label={`Ir a diapositiva ${idx + 1}`}
      ></button>
    ))}
  </div>
</section>

<script>
  const slides = document.querySelectorAll('.hero-slide');
  const contents = document.querySelectorAll('.hero-content-block');
  const dots = document.querySelectorAll('.hero-dot');
  let currentIdx = 0;
  const intervalTime = 6000;
  let intervalId: any;

  function showSlide(index: number) {
    slides.forEach((slide, idx) => {
      if (idx === index) {
        slide.classList.remove('opacity-0', 'z-0');
        slide.classList.add('opacity-100', 'z-10');
      } else {
        slide.classList.remove('opacity-100', 'z-10');
        slide.classList.add('opacity-0', 'z-0');
      }
    });

    contents.forEach((content, idx) => {
      if (idx === index) {
        content.classList.remove('hidden');
        setTimeout(() => content.classList.add('opacity-100'), 50);
      } else {
        content.classList.add('hidden');
        content.classList.remove('opacity-100');
      }
    });

    dots.forEach((dot, idx) => {
      if (idx === index) {
        dot.classList.add('bg-white', 'scale-125');
      } else {
        dot.classList.remove('bg-white', 'scale-125');
      }
    });

    currentIdx = index;
  }

  function nextSlide() {
    let next = (currentIdx + 1) % slides.length;
    showSlide(next);
  }

  function startAutoplay() {
    intervalId = setInterval(nextSlide, intervalTime);
  }

  function resetAutoplay() {
    clearInterval(intervalId);
    startAutoplay();
  }

  dots.forEach(dot => {
    dot.addEventListener('click', (e: any) => {
      const idx = parseInt(e.target.dataset.index);
      showSlide(idx);
      resetAutoplay();
    });
  });

  startAutoplay();
</script>
